generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Listing {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  type        String
  bedrooms    Int
  bathrooms   Int
  maxGuests   Int
  pricePerNight Float
  cleaningFee   Float  @default(0)
  amenities   String[]
  photos      String[]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  closedDates  ClosedDate[]
  reservations Reservation[]
  galleryItems ListingMedia[]
}

model Media {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  url          String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())

  listingMedia ListingMedia[]
  pageMedia    PageMedia[]
}

model ListingMedia {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  mediaId   String
  media     Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  room      String
  label     String
  sortOrder Int     @default(0)

  @@index([listingId])
}

model PageMedia {
  id       String @id @default(cuid())
  location String @unique
  mediaId  String
  media    Media  @relation(fields: [mediaId], references: [id])
}

model SiteContent {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  section   String
  label     String
  updatedAt DateTime @updatedAt
}

model ClosedDate {
  id        String   @id @default(cuid())
  date      DateTime
  reason    String?
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, date])
}

model Reservation {
  id            String   @id @default(cuid())
  guestName     String
  guestEmail    String
  guestPhone    String?
  checkIn       DateTime
  checkOut      DateTime
  guests        Int
  totalPrice    Float
  status        String   @default("pending")
  notes         String?
  listingId     String
  listing       Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accessCode    String?
  agreement     ReservationAgreement?
  guestRequests GuestRequest[]
}

model ReservationAgreement {
  id            String      @id @default(cuid())
  reservationId String      @unique
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  signedName    String
  signedAt      DateTime    @default(now())
  ipAddress     String?
  documentHash  String
}

model InventoryItem {
  id        String @id @default(cuid())
  listingId String
  room      String
  itemName  String
  quantity  Int    @default(1)
  sortOrder Int    @default(0)

  @@index([listingId])
}

model CheckinInstruction {
  id        String @id @default(cuid())
  listingId String
  category  String
  title     String
  value     String
  sortOrder Int    @default(0)

  @@index([listingId])
}

model LocalRecommendation {
  id          String  @id @default(cuid())
  category    String
  name        String
  description String
  address     String?
  link        String?
  imageUrl    String?
  sortOrder   Int     @default(0)
}

model GuestRequest {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  type          String
  message       String
  status        String      @default("pending")
  adminReply    String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([reservationId])
}

// ─── Expense & Financial Models ───────────────────────────────────────

model Vendor {
  id         String   @id @default(cuid())
  vendorName String
  vendorType String
  contactName String?
  phone      String?
  email      String?
  website    String?
  notes      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  expenses           Expense[]
  recurringExpenses  RecurringExpense[]
  propertyInventory  PropertyInventory[]
  inventoryPurchases InventoryPurchase[]
  maintenanceLogs    MaintenanceLog[]
}

model ExpenseCategory {
  id          String   @id @default(cuid())
  name        String
  type        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  expenses          Expense[]
  recurringExpenses RecurringExpense[]
}

model Expense {
  id            String   @id @default(cuid())
  propertyId    String
  unitId        String?
  bookingId     String?
  categoryId    String
  subcategory   String?
  vendorId      String?
  expenseDate   DateTime
  amount        Float
  paymentMethod String?
  paymentStatus String   @default("pending")
  frequency     String   @default("one-time")
  isRecurring   Boolean  @default(false)
  receiptUrl    String?
  notes         String?
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category ExpenseCategory @relation(fields: [categoryId], references: [id])
  vendor   Vendor?         @relation(fields: [vendorId], references: [id])

  @@index([propertyId])
  @@index([categoryId])
}

model RecurringExpense {
  id            String    @id @default(cuid())
  propertyId    String
  categoryId    String
  vendorId      String?
  name          String
  amount        Float
  frequency     String
  dueDay        Int?
  nextDueDate   DateTime?
  autoPay       Boolean   @default(false)
  paymentStatus String    @default("pending")
  notes         String?
  createdAt     DateTime  @default(now())

  category ExpenseCategory @relation(fields: [categoryId], references: [id])
  vendor   Vendor?         @relation(fields: [vendorId], references: [id])

  @@index([propertyId])
}

model BookingExpense {
  id               String   @id @default(cuid())
  bookingId        String
  propertyId       String
  expenseId        String?
  expenseType      String
  amount           Float
  allocationMethod String   @default("direct")
  notes            String?
  createdAt        DateTime @default(now())

  @@index([bookingId])
}

model PropertyBill {
  id                 String    @id @default(cuid())
  propertyId         String
  billType           String
  provider           String?
  billingPeriodStart DateTime?
  billingPeriodEnd   DateTime?
  amountDue          Float
  amountPaid         Float     @default(0)
  dueDate            DateTime?
  paidDate           DateTime?
  paymentStatus      String    @default("unpaid")
  receiptUrl         String?
  notes              String?
  createdAt          DateTime  @default(now())

  @@index([propertyId])
}

model UtilityReading {
  id           String    @id @default(cuid())
  propertyId   String
  utilityType  String
  readingDate  DateTime
  meterReading Float?
  usageAmount  Float?
  billAmount   Float?
  notes        String?
  createdAt    DateTime  @default(now())

  @@index([propertyId])
}

model PropertyInventory {
  id                String    @id @default(cuid())
  propertyId        String
  unitId            String?
  itemName          String
  category          String
  sku               String?
  quantityOnHand    Int       @default(0)
  reorderThreshold  Int       @default(0)
  unitCost          Float     @default(0)
  avgUnitCost       Float     @default(0)
  replacementCost   Float     @default(0)
  remainingValue    Float     @default(0)
  vendorId          String?
  purchaseDate      DateTime?
  expectedLifeMonths Int?
  conditionStatus   String    @default("good")
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  vendor       Vendor?              @relation(fields: [vendorId], references: [id])
  purchases    InventoryPurchase[]
  usages       InventoryUsage[]
  replacements InventoryReplacement[]

  @@index([propertyId])
}

model InventoryPurchase {
  id                String   @id @default(cuid())
  propertyId        String
  unitId            String?
  itemId            String
  vendorId          String?
  purchaseDate      DateTime
  quantityPurchased Int
  unitCost          Float
  totalCost         Float
  receiptUrl        String?
  notes             String?
  createdAt         DateTime @default(now())

  item   PropertyInventory @relation(fields: [itemId], references: [id])
  vendor Vendor?           @relation(fields: [vendorId], references: [id])

  @@index([propertyId])
  @@index([itemId])
}

model InventoryUsage {
  id               String   @id @default(cuid())
  propertyId       String
  unitId           String?
  bookingId        String?
  itemId           String
  usageDate        DateTime
  quantityUsed     Int
  unitCostAtUsage  Float    @default(0)
  totalUsageCost   Float    @default(0)
  reason           String   @default("guest_stay")
  notes            String?
  createdAt        DateTime @default(now())

  item PropertyInventory @relation(fields: [itemId], references: [id])

  @@index([propertyId])
  @@index([itemId])
}

model InventoryReplacement {
  id                     String    @id @default(cuid())
  propertyId             String
  unitId                 String?
  itemId                 String
  replacementDate        DateTime?
  quantityReplaced       Int       @default(0)
  replacementCostPerItem Float     @default(0)
  totalReplacementCost   Float     @default(0)
  reason                 String    @default("worn")
  priority               String    @default("medium")
  status                 String    @default("needed")
  notes                  String?
  createdAt              DateTime  @default(now())

  item PropertyInventory @relation(fields: [itemId], references: [id])

  @@index([propertyId])
}

model MaintenanceLog {
  id              String   @id @default(cuid())
  propertyId      String
  unitId          String?
  bookingId       String?
  vendorId        String?
  maintenanceDate DateTime
  issueType       String
  description     String
  cost            Float    @default(0)
  status          String   @default("open")
  receiptUrl      String?
  notes           String?
  createdAt       DateTime @default(now())

  vendor Vendor? @relation(fields: [vendorId], references: [id])

  @@index([propertyId])
}

model MonthlyPnlReport {
  id                      String   @id @default(cuid())
  propertyId              String
  month                   Int
  year                    Int
  grossRevenue            Float    @default(0)
  platformFees            Float    @default(0)
  paymentProcessingFees   Float    @default(0)
  netRevenue              Float    @default(0)
  fixedExpenses           Float    @default(0)
  variableExpenses        Float    @default(0)
  inventoryPurchased      Float    @default(0)
  inventoryUsed           Float    @default(0)
  replacementReserveNeeded Float   @default(0)
  totalExpenses           Float    @default(0)
  netOperatingIncome      Float    @default(0)
  netProfit               Float    @default(0)
  profitMargin            Float    @default(0)
  createdAt               DateTime @default(now())

  @@unique([propertyId, month, year])
}

model WeeklyExpenseSummary {
  id                 String   @id @default(cuid())
  propertyId         String
  weekStart          DateTime
  weekEnd            DateTime
  grossRevenue       Float    @default(0)
  occupiedNights     Int      @default(0)
  cleaningExpenses   Float    @default(0)
  laundryExpenses    Float    @default(0)
  suppliesUsed       Float    @default(0)
  utilitiesAllocated Float    @default(0)
  repairs            Float    @default(0)
  maintenance        Float    @default(0)
  inventoryUsed      Float    @default(0)
  totalExpenses      Float    @default(0)
  netProfit          Float    @default(0)
  profitMargin       Float    @default(0)
  createdAt          DateTime @default(now())

  @@index([propertyId])
}
