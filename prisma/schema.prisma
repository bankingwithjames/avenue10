generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Listing {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String
  type        String
  bedrooms    Int
  bathrooms   Int
  maxGuests   Int
  pricePerNight Float
  cleaningFee   Float  @default(0)
  amenities   String[]
  photos      String[]
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  closedDates   ClosedDate[]
  reservations  Reservation[]
  galleryItems  ListingMedia[]
  pricingConfig PricingConfig?
  dailyRates    FinalDailyRate[]
  pricingRules  PricingRule[]
  pricingLogs   PricingChangeLog[]
  contentLinks  ListingContentLink[]
  bookingQuotes BookingQuote[]
  bookingRule   BookingRule?
  salesConfig   SalesConfig?
  dynamicPricingSettings DynamicPricingSettings?
  promoCodes    PromoCode[]
  abandonedCheckouts AbandonedCheckout[]
  salesActivityLogs  SalesActivityLog[]
}

model Media {
  id           String   @id @default(cuid())
  filename     String
  originalName String
  url          String
  mimeType     String
  size         Int
  createdAt    DateTime @default(now())

  listingMedia ListingMedia[]
  pageMedia    PageMedia[]
}

model ListingMedia {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  mediaId   String
  media     Media   @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  room      String
  label     String
  sortOrder Int     @default(0)

  @@index([listingId])
}

model PageMedia {
  id       String @id @default(cuid())
  location String @unique
  mediaId  String
  media    Media  @relation(fields: [mediaId], references: [id])
}

model SiteContent {
  id           String               @id @default(cuid())
  key          String               @unique
  value        String
  section      String
  label        String
  updatedAt    DateTime             @updatedAt
  contentLinks ListingContentLink[]
}

model ClosedDate {
  id        String   @id @default(cuid())
  date      DateTime
  reason    String?
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, date])
}

model Reservation {
  id            String   @id @default(cuid())
  guestName     String
  guestEmail    String
  guestPhone    String?
  checkIn       DateTime
  checkOut      DateTime
  guests        Int
  totalPrice    Float
  status        String   @default("pending")
  notes         String?
  listingId     String
  listing       Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  accessCode    String?
  channel       String?
  portalToken   String?  @unique
  portalExpires DateTime?
  portalRevoked Boolean  @default(false)

  quoteId          String?
  guestId          String?
  guest            Guest?   @relation(fields: [guestId], references: [id], onDelete: SetNull)
  bookingMode      String?
  nightlyBreakdown Json?
  subtotal         Float?
  cleaningFeeCharged Float?
  petFeeCharged    Float?
  extraGuestFeeCharged Float?
  taxAmount        Float?
  serviceFeeCharged Float?
  depositHoldCharged Float?
  addOnsTotalCharged Float?
  addOnsDetail       Json?
  paymentStatus    String   @default("none")
  depositAmount    Float?
  depositPaidAt    DateTime?
  confirmationCode String?  @unique
  adminNotes       String?
  approvedBy       String?
  approvedAt       DateTime?
  declinedReason   String?

  agreement     ReservationAgreement?
  agreementSnapshot BookingAgreementSnapshot?
  changeOrders  ReservationChangeOrder[]
  guestRequests GuestRequest[]
  guestReviews  GuestReview[]
  portalLogs    GuestPortalLog[]
  notifications BookingNotification[]
  checkoutSession CheckoutSession?
}

model ReservationAgreement {
  id            String      @id @default(cuid())
  reservationId String      @unique
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  signedName    String
  signedAt      DateTime    @default(now())
  ipAddress     String?
  userAgent     String?
  documentHash  String
}

model InventoryItem {
  id               String    @id @default(cuid())
  listingId        String
  room             String
  itemName         String
  category         String    @default("General")
  quantity         Int       @default(1)
  quantityExpected Int       @default(1)
  condition        String    @default("good")
  replacementCost  Float     @default(0)
  guestVisible     Boolean   @default(true)
  lastChecked      DateTime?
  photoUrl         String?
  notes            String?
  sortOrder        Int       @default(0)

  inventoryReports GuestInventoryReport[]

  @@index([listingId])
}

model CheckinInstruction {
  id                 String  @id @default(cuid())
  listingId          String
  category           String
  title              String
  value              String
  sensitive          Boolean @default(false)
  visibleBeforeHours Int     @default(0)
  adminNotes         String?
  sortOrder          Int     @default(0)

  @@index([listingId])
}

model LocalRecommendation {
  id           String  @id @default(cuid())
  category     String
  name         String
  description  String
  address      String?
  link         String?
  phone        String?
  imageUrl     String?
  distance     String?
  priceRange   String?
  bestFor      String?
  mapLink      String?
  guestVisible Boolean @default(true)
  featured     Boolean @default(false)
  sortOrder    Int     @default(0)
}

model GuestRequest {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  type          String
  message       String
  category      String      @default("general")
  priority      String      @default("normal")
  status        String      @default("new")
  assignedStaff String?
  internalNotes String?
  adminReply    String?
  photos        String[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([reservationId])
}

// ─── Guest Review System ─────────────────────────────────────────────

model GuestReview {
  id                String      @id @default(cuid())
  reservationId     String
  reservation       Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  overallRating     Int         @default(5)
  cleanlinessRating Int?
  accuracyRating    Int?
  communicationRating Int?
  locationRating    Int?
  valueRating       Int?
  comments          String?
  adminResponse     String?
  publishToWebsite  Boolean     @default(false)
  featured          Boolean     @default(false)
  source            String      @default("direct")
  approvalStatus    String      @default("pending")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@index([reservationId])
}

model GuestInventoryReport {
  id          String        @id @default(cuid())
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  reportType  String
  description String?
  photos      String[]
  status      String        @default("new")
  createdAt   DateTime      @default(now())

  @@index([itemId])
}

model GuestPortalLog {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  action        String
  details       String?
  ipAddress     String?
  createdAt     DateTime    @default(now())

  @@index([reservationId])
}

// ─── Expense & Financial Models ───────────────────────────────────────

model Vendor {
  id         String   @id @default(cuid())
  vendorName String
  vendorType String
  contactName String?
  phone      String?
  email      String?
  website    String?
  notes      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  expenses           Expense[]
  recurringExpenses  RecurringExpense[]
  propertyInventory  PropertyInventory[]
  inventoryPurchases InventoryPurchase[]
  maintenanceLogs    MaintenanceLog[]
}

model ExpenseCategory {
  id          String   @id @default(cuid())
  name        String
  type        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  expenses          Expense[]
  recurringExpenses RecurringExpense[]
}

model Expense {
  id            String   @id @default(cuid())
  propertyId    String
  unitId        String?
  bookingId     String?
  categoryId    String
  subcategory   String?
  vendorId      String?
  expenseDate   DateTime
  amount        Float
  paymentMethod String?
  paymentStatus String   @default("pending")
  frequency     String   @default("one-time")
  isRecurring   Boolean  @default(false)
  receiptUrl    String?
  notes         String?
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category ExpenseCategory @relation(fields: [categoryId], references: [id])
  vendor   Vendor?         @relation(fields: [vendorId], references: [id])

  @@index([propertyId])
  @@index([categoryId])
}

model RecurringExpense {
  id            String    @id @default(cuid())
  propertyId    String
  categoryId    String
  vendorId      String?
  name          String
  amount        Float
  frequency     String
  dueDay        Int?
  nextDueDate   DateTime?
  autoPay       Boolean   @default(false)
  paymentStatus String    @default("pending")
  notes         String?
  createdAt     DateTime  @default(now())

  category ExpenseCategory @relation(fields: [categoryId], references: [id])
  vendor   Vendor?         @relation(fields: [vendorId], references: [id])

  @@index([propertyId])
}

model BookingExpense {
  id               String   @id @default(cuid())
  bookingId        String
  propertyId       String
  expenseId        String?
  expenseType      String
  amount           Float
  allocationMethod String   @default("direct")
  notes            String?
  createdAt        DateTime @default(now())

  @@index([bookingId])
}

model PropertyBill {
  id                 String    @id @default(cuid())
  propertyId         String
  billType           String
  provider           String?
  billingPeriodStart DateTime?
  billingPeriodEnd   DateTime?
  amountDue          Float
  amountPaid         Float     @default(0)
  dueDate            DateTime?
  paidDate           DateTime?
  paymentStatus      String    @default("unpaid")
  receiptUrl         String?
  notes              String?
  createdAt          DateTime  @default(now())

  @@index([propertyId])
}

model UtilityReading {
  id           String    @id @default(cuid())
  propertyId   String
  utilityType  String
  readingDate  DateTime
  meterReading Float?
  usageAmount  Float?
  billAmount   Float?
  notes        String?
  createdAt    DateTime  @default(now())

  @@index([propertyId])
}

model PropertyInventory {
  id                   String    @id @default(cuid())
  propertyId           String
  unitId               String?
  roomId               String?
  itemName             String
  category             String
  itemType             String    @default("reusable")
  description          String?
  sku                  String?
  quantityExpected     Int       @default(1)
  quantityOnHand       Int       @default(0)
  quantityUsed         Int       @default(0)
  quantityMissing      Int       @default(0)
  reorderThreshold     Int       @default(0)
  unitCost             Float     @default(0)
  avgUnitCost          Float     @default(0)
  replacementCost      Float     @default(0)
  remainingValue       Float     @default(0)
  inventoryStatus      String    @default("ok")
  conditionStatus      String    @default("good")
  vendorId             String?
  purchaseDate         DateTime?
  expectedLifeMonths   Int?
  lastCheckedAt        DateTime?
  lastRestockedAt      DateTime?
  guestVisible         Boolean   @default(false)
  cleanerCheckRequired Boolean   @default(false)
  receiptUrl           String?
  photoUrl             String?
  notes                String?
  archivedAt           DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  room         InventoryRoom?       @relation(fields: [roomId], references: [id], onDelete: SetNull)
  vendor       Vendor?              @relation(fields: [vendorId], references: [id])
  purchases    InventoryPurchase[]
  usages       InventoryUsage[]
  replacements InventoryReplacement[]
  issues       InventoryIssue[]
  cleanerChecks CleanerInventoryCheck[]

  @@index([propertyId])
  @@index([roomId])
}

model InventoryPurchase {
  id                String   @id @default(cuid())
  propertyId        String
  unitId            String?
  itemId            String
  vendorId          String?
  purchaseDate      DateTime
  quantityPurchased Int
  unitCost          Float
  totalCost         Float
  receiptUrl        String?
  notes             String?
  createdAt         DateTime @default(now())

  item   PropertyInventory @relation(fields: [itemId], references: [id])
  vendor Vendor?           @relation(fields: [vendorId], references: [id])

  @@index([propertyId])
  @@index([itemId])
}

model InventoryUsage {
  id               String   @id @default(cuid())
  propertyId       String
  unitId           String?
  bookingId        String?
  itemId           String
  usageDate        DateTime
  quantityUsed     Int
  unitCostAtUsage  Float    @default(0)
  totalUsageCost   Float    @default(0)
  reason           String   @default("guest_stay")
  notes            String?
  createdAt        DateTime @default(now())

  item PropertyInventory @relation(fields: [itemId], references: [id])

  @@index([propertyId])
  @@index([itemId])
}

model InventoryReplacement {
  id                     String    @id @default(cuid())
  propertyId             String
  unitId                 String?
  itemId                 String
  replacementDate        DateTime?
  quantityReplaced       Int       @default(0)
  replacementCostPerItem Float     @default(0)
  totalReplacementCost   Float     @default(0)
  reason                 String    @default("worn")
  priority               String    @default("medium")
  status                 String    @default("needed")
  notes                  String?
  createdAt              DateTime  @default(now())

  item PropertyInventory @relation(fields: [itemId], references: [id])

  @@index([propertyId])
}

model MaintenanceLog {
  id              String    @id @default(cuid())
  propertyId      String
  unitId          String?
  bookingId       String?
  vendorId        String?
  maintenanceDate DateTime
  issueType       String
  description     String
  cost            Float     @default(0)
  status          String    @default("open")
  receiptUrl      String?
  notes           String?
  createdAt       DateTime  @default(now())

  // New fields
  listingId          String?
  roomId             String?
  inventoryItemId    String?
  guestRequestId     String?
  issueTitle         String?
  category           String?
  priority           String    @default("medium")
  reportedBy         String?
  scheduledDate      DateTime?
  startTime          DateTime?
  endTime            DateTime?
  dueDate            DateTime?
  completedDate      DateTime?
  estimatedCost      Float     @default(0)
  actualCost         Float     @default(0)
  laborCost          Float     @default(0)
  materialsCost      Float     @default(0)
  beforePhotoUrl     String?
  afterPhotoUrl      String?
  createdBy          String?
  updatedAt          DateTime  @updatedAt

  vendor             Vendor?   @relation(fields: [vendorId], references: [id])
  calendarEvents     MaintenanceCalendarEvent[]
  files              MaintenanceFile[]
  activityLogs       MaintenanceActivityLog[]

  @@index([propertyId])
  @@index([vendorId])
  @@index([status])
}

model MaintenanceCalendarEvent {
  id                 String    @id @default(cuid())
  maintenanceLogId   String
  propertyId         String
  listingId          String?
  title              String
  startDatetime      DateTime
  endDatetime        DateTime?
  calendarViewStatus String    @default("scheduled")
  colorStatus        String?
  isRecurring        Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  maintenanceLog     MaintenanceLog @relation(fields: [maintenanceLogId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([maintenanceLogId])
}

model RecurringMaintenanceTask {
  id                String    @id @default(cuid())
  propertyId        String
  listingId         String?
  roomId            String?
  taskName          String
  category          String
  frequency         String    @default("monthly")
  nextDueDate       DateTime?
  lastCompletedDate DateTime?
  vendorId          String?
  estimatedCost     Float     @default(0)
  reminderDaysBefore Int      @default(7)
  autoCreateEvent   Boolean   @default(true)
  status            String    @default("active")
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([propertyId])
}

model MaintenanceFile {
  id                 String   @id @default(cuid())
  maintenanceLogId   String
  fileUrl            String
  fileType           String?
  fileName           String?
  fileCategory       String   @default("photo")
  uploadedBy         String?
  createdAt          DateTime @default(now())

  maintenanceLog     MaintenanceLog @relation(fields: [maintenanceLogId], references: [id], onDelete: Cascade)

  @@index([maintenanceLogId])
}

model MaintenanceActivityLog {
  id                 String   @id @default(cuid())
  maintenanceLogId   String
  activityType       String
  oldValue           String?
  newValue           String?
  note               String?
  createdBy          String?
  createdAt          DateTime @default(now())

  maintenanceLog     MaintenanceLog @relation(fields: [maintenanceLogId], references: [id], onDelete: Cascade)

  @@index([maintenanceLogId])
}

model MonthlyPnlReport {
  id                      String   @id @default(cuid())
  propertyId              String
  month                   Int
  year                    Int
  grossRevenue            Float    @default(0)
  platformFees            Float    @default(0)
  paymentProcessingFees   Float    @default(0)
  netRevenue              Float    @default(0)
  fixedExpenses           Float    @default(0)
  variableExpenses        Float    @default(0)
  inventoryPurchased      Float    @default(0)
  inventoryUsed           Float    @default(0)
  replacementReserveNeeded Float   @default(0)
  totalExpenses           Float    @default(0)
  netOperatingIncome      Float    @default(0)
  netProfit               Float    @default(0)
  profitMargin            Float    @default(0)
  createdAt               DateTime @default(now())

  @@unique([propertyId, month, year])
}

model WeeklyExpenseSummary {
  id                 String   @id @default(cuid())
  propertyId         String
  weekStart          DateTime
  weekEnd            DateTime
  grossRevenue       Float    @default(0)
  occupiedNights     Int      @default(0)
  cleaningExpenses   Float    @default(0)
  laundryExpenses    Float    @default(0)
  suppliesUsed       Float    @default(0)
  utilitiesAllocated Float    @default(0)
  repairs            Float    @default(0)
  maintenance        Float    @default(0)
  inventoryUsed      Float    @default(0)
  totalExpenses      Float    @default(0)
  netProfit          Float    @default(0)
  profitMargin       Float    @default(0)
  createdAt          DateTime @default(now())

  @@index([propertyId])
}

// ─── Pricing System (Source of Truth) ────────────────────────────────

model PricingConfig {
  id                    String   @id @default(cuid())
  listingId             String   @unique
  listing               Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  baseNightlyRate       Float    @default(0)
  cleaningFee           Float    @default(0)
  weekendRate           Float?
  minRate               Float?
  maxRate               Float?
  petFee                Float    @default(0)
  extraGuestFee         Float    @default(0)
  securityDeposit       Float    @default(0)
  minimumStay           Int      @default(1)
  dynamicPricingEnabled Boolean  @default(false)
  pricingProvider       String?
  updatedAt             DateTime @updatedAt
}

model FinalDailyRate {
  id                 String   @id @default(cuid())
  listingId          String
  listing            Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  date               DateTime
  finalRate          Float
  rateSource         String   @default("base")
  baseRate           Float?
  ruleAdjustedRate   Float?
  aiSuggestedRate    Float?
  approvedAiRate     Float?
  manualOverrideRate Float?
  isLocked           Boolean  @default(false)
  syncStatus         String   @default("synced")
  updatedAt          DateTime @updatedAt

  @@unique([listingId, date])
  @@index([listingId])
}

model PricingRule {
  id              String   @id @default(cuid())
  listingId       String
  listing         Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  ruleType        String
  ruleName        String
  adjustmentType  String   @default("percentage")
  adjustmentValue Float    @default(0)
  appliesTo       String   @default("all")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([listingId])
}

model PricingChangeLog {
  id                  String   @id @default(cuid())
  listingId           String
  listing             Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  changedField        String
  oldValue            String?
  newValue            String?
  changedFromPage     String   @default("listings")
  changedBy           String?
  affectsFinalPricing Boolean  @default(true)
  createdAt           DateTime @default(now())

  @@index([listingId])
}

// ─── Content Linking System ──────────────────────────────────────────

model ListingContentLink {
  id             String       @id @default(cuid())
  listingId      String
  listing        Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  contentKey     String
  siteContentId  String?
  siteContent    SiteContent? @relation(fields: [siteContentId], references: [id])
  usageLocation  String       @default("listing")
  isSynced       Boolean      @default(true)
  overrideValue  String?
  allowsOverride Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([listingId, contentKey])
  @@index([listingId])
}

// ─── Inventory Management System ──────────────────────────────────────

model InventoryRoom {
  id           String   @id @default(cuid())
  propertyId   String
  listingId    String?
  roomName     String
  roomType     String   @default("other")
  displayOrder Int      @default(0)
  notes        String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items        PropertyInventory[]

  @@index([propertyId])
}

model InventoryIssue {
  id               String    @id @default(cuid())
  propertyId       String
  listingId        String?
  roomId           String?
  itemId           String?
  bookingId        String?
  issueType        String
  issueDescription String
  priority         String    @default("medium")
  status           String    @default("open")
  reportedBy       String?
  photoUrl         String?
  replacementCost  Float     @default(0)
  resolvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  item PropertyInventory? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([itemId])
}

model CleanerInventoryCheck {
  id               String   @id @default(cuid())
  propertyId       String
  listingId        String?
  bookingId        String?
  roomId           String?
  itemId           String?
  expectedQuantity Int      @default(0)
  actualQuantity   Int      @default(0)
  conditionStatus  String   @default("good")
  status           String   @default("complete")
  cleanerNotes     String?
  photoUrl         String?
  checkedBy        String?
  checkedAt        DateTime @default(now())

  item PropertyInventory? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([propertyId])
  @@index([itemId])
}

// ─── Booking Workflow ─────────────────────────────────────────────────

model BookingQuote {
  id               String   @id @default(cuid())
  listingId        String
  listing          Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  checkIn          DateTime
  checkOut         DateTime
  guests           Int
  nights           Int
  nightlyBreakdown Json
  subtotal         Float
  cleaningFee      Float    @default(0)
  petFee           Float    @default(0)
  extraGuestFee    Float    @default(0)
  taxAmount        Float    @default(0)
  serviceFee       Float    @default(0)
  depositHold      Float    @default(0)
  addOnsTotal      Float    @default(0)
  addOnsBreakdown  Json?
  total            Float
  currency         String   @default("USD")
  status           String   @default("active")
  expiresAt        DateTime
  createdAt        DateTime @default(now())

  checkoutSession  CheckoutSession?
  quoteAddOns      BookingQuoteAddon[]

  @@index([listingId])
  @@index([status, expiresAt])
}

model BookingRule {
  id                    String   @id @default(cuid())
  listingId             String   @unique
  listing               Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bookingMode           String   @default("request_to_book")
  requireIdVerification Boolean  @default(false)
  requireAgreement      Boolean  @default(true)
  depositPercent        Float    @default(0)
  depositFlat           Float    @default(0)
  cancellationPolicy    String   @default("flexible")
  minAdvanceDays        Int      @default(0)
  maxAdvanceDays        Int      @default(365)
  instantBookMaxNights  Int?
  autoApproveReturning  Boolean  @default(false)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model CheckoutSession {
  id              String   @id @default(cuid())
  quoteId         String   @unique
  quote           BookingQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  reservationId   String?  @unique
  reservation     Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  step            String   @default("guest_info")
  guestFirstName  String?
  guestLastName   String?
  guestEmail      String?
  guestPhone      String?
  specialRequests String?
  status          String   @default("in_progress")
  expiresAt       DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, expiresAt])
}

model BookingNotification {
  id            String    @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  type          String
  channel       String    @default("email")
  recipient     String
  subject       String?
  body          String?
  status        String    @default("pending")
  sentAt        DateTime?
  error         String?
  createdAt     DateTime  @default(now())

  @@index([reservationId])
}

// ─── Sales Management ─────────────────────────────────────────────────

model SalesConfig {
  id                String   @id @default(cuid())
  listingId         String   @unique
  listing           Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  boardRate         Float    @default(0)
  weekendRate       Float?
  cleaningFee       Float    @default(0)

  taxRate           Float    @default(0)
  taxLabel          String   @default("Taxes & Fees")

  serviceFeePercent Float    @default(0)
  serviceFeeFlat    Float    @default(0)
  serviceFeeLabel   String   @default("Service Fee")

  depositHoldPercent Float   @default(0)
  depositHoldFlat    Float   @default(0)
  depositHoldLabel   String  @default("Security Deposit Hold")

  petFee            Float    @default(0)
  extraGuestFee     Float    @default(0)
  extraGuestThreshold Int    @default(2)

  guestsIncluded    Int      @default(2)
  maxGuests         Int      @default(10)
  minimumStay       Int      @default(1)
  maximumStay        Int      @default(30)
  sameDayBookingAllowed Boolean @default(false)
  advanceNoticeHours Int     @default(24)

  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  addOns            AddOnItem[]
}

model AddOnItem {
  id              String      @id @default(cuid())
  salesConfigId   String
  salesConfig     SalesConfig @relation(fields: [salesConfigId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  price           Float
  category        String      @default("service")
  pricingType     String      @default("flat")
  guestVisible    Boolean     @default(true)
  requiresAdminApproval Boolean @default(false)
  requiresInventory Boolean   @default(false)
  taxable         Boolean     @default(true)
  isActive        Boolean     @default(true)
  sortOrder       Int         @default(0)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  quoteAddOns     BookingQuoteAddon[]

  @@index([salesConfigId])
}

model BookingQuoteAddon {
  id            String    @id @default(cuid())
  quoteId       String
  quote         BookingQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  addOnItemId   String
  addOnItem     AddOnItem @relation(fields: [addOnItemId], references: [id], onDelete: Cascade)
  quantity      Int       @default(1)
  priceSnapshot Float
  totalPrice    Float
  createdAt     DateTime  @default(now())

  @@index([quoteId])
  @@index([addOnItemId])
}

// ─── Dynamic Pricing ─────────────────────────────────────────────────

model DynamicPricingSettings {
  id                        String   @id @default(cuid())
  listingId                 String   @unique
  listing                   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  enabled                   Boolean  @default(false)
  pricingMode               String   @default("balanced")
  minimumRate               Float    @default(0)
  maximumRate               Float    @default(0)
  weekendPremiumPercent     Float    @default(0)
  eventPremiumPercent       Float    @default(0)
  gapNightDiscountPercent   Float    @default(0)
  lastMinuteDiscountPercent Float    @default(0)
  farOutPremiumPercent      Float    @default(0)
  occupancyBasedEnabled     Boolean  @default(false)
  bookingPaceEnabled        Boolean  @default(false)
  marketCompEnabled         Boolean  @default(false)
  manualPriceLockEnabled    Boolean  @default(false)
  pricingProvider           String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

// ─── Booking Agreement Snapshot ──────────────────────────────────────

model BookingAgreementSnapshot {
  id                   String      @id @default(cuid())
  reservationId        String      @unique
  reservation          Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  guestId              String?
  nightlyRateSnapshot  Json
  cleaningFeeSnapshot  Float       @default(0)
  taxesSnapshot        Float       @default(0)
  serviceFeeSnapshot   Float       @default(0)
  depositHoldSnapshot  Float       @default(0)
  addOnsSnapshot       Json?
  discountsSnapshot    Json?
  totalPriceSnapshot   Float       @default(0)
  termsAccepted        Boolean     @default(true)
  cancellationPolicy   String      @default("flexible")
  paymentStatus        String      @default("none")
  createdAt            DateTime    @default(now())
}

// ─── Reservation Change Orders ───────────────────────────────────────

model ReservationChangeOrder {
  id                    String      @id @default(cuid())
  reservationId         String
  reservation           Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  guestId               String?
  changeType            String
  description           String?
  originalValue         String?
  newValue              String?
  originalPrice         Float       @default(0)
  newPrice              Float       @default(0)
  priceDifference       Float       @default(0)
  adminApprovalRequired Boolean     @default(false)
  guestApprovalRequired Boolean     @default(false)
  approvalStatus        String      @default("pending")
  paymentStatus         String      @default("none")
  invoiceUrl            String?
  notes                 String?
  processedBy           String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([reservationId])
}

// ─── Promo Codes ─────────────────────────────────────────────────────

model PromoCode {
  id             String    @id @default(cuid())
  code           String    @unique
  discountType   String    @default("percentage")
  discountValue  Float     @default(0)
  listingId      String?
  listing        Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  startDate      DateTime?
  endDate        DateTime?
  minimumNights  Int       @default(1)
  maxUses        Int       @default(0)
  currentUses    Int       @default(0)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// ─── Abandoned Checkouts ─────────────────────────────────────────────

model AbandonedCheckout {
  id              String    @id @default(cuid())
  quoteId         String?
  guestEmail      String?
  guestPhone      String?
  listingId       String?
  listing         Listing?  @relation(fields: [listingId], references: [id], onDelete: SetNull)
  checkIn         DateTime?
  checkOut        DateTime?
  totalQuote      Float     @default(0)
  abandonedStep   String?
  abandonedAt     DateTime  @default(now())
  followUpStatus  String    @default("none")
  createdAt       DateTime  @default(now())

  @@index([listingId])
}

// ─── Sales Activity Log ──────────────────────────────────────────────

model SalesActivityLog {
  id           String   @id @default(cuid())
  listingId    String?
  listing      Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  activityType String
  description  String?
  oldValue     String?
  newValue     String?
  changedBy    String?
  createdAt    DateTime @default(now())

  @@index([listingId])
}

// ─── Guest CRM System ─────────────────────────────────────────────────

model Guest {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  email           String   @unique
  phone           String?
  status          String   @default("active")
  guestType       String   @default("leisure")
  isVip           Boolean  @default(false)
  doNotHost       Boolean  @default(false)
  doNotContact    Boolean  @default(false)
  emailOptIn      Boolean  @default(true)
  smsOptIn        Boolean  @default(false)
  marketingOptIn  Boolean  @default(true)
  preferredContact String  @default("email")
  source          String   @default("direct")
  lifetimeRevenue Float    @default(0)
  totalBookings   Int      @default(0)
  internalNotes   String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reservations    Reservation[]
  accommodation   GuestAccommodation?
  tags            GuestTagAssignment[]
  notes           GuestNote[]
  messages        GuestMessage[]
  campaignRecipients CampaignRecipient[]
  activityLogs    CrmActivityLog[]
}

model GuestAccommodation {
  id                     String   @id @default(cuid())
  guestId                String   @unique
  guest                  Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  accessibilityNeeds     String?
  familyNeeds            String?
  petNotes               String?
  parkingNeeds           String?
  sleepingPreferences    String?
  temperaturePreferences String?
  allergies              String?
  specialOccasions       String?
  preferredCheckinTime   String?
  preferredCheckoutTime  String?
  preferredListing       String?
  favoriteAmenities      String[]
  hostNotes              String?
  updatedAt              DateTime @updatedAt
}

model GuestTag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#6b7280")

  assignments GuestTagAssignment[]
}

model GuestTagAssignment {
  id      String   @id @default(cuid())
  guestId String
  tagId   String
  guest   Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  tag     GuestTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([guestId, tagId])
}

model GuestNote {
  id        String   @id @default(cuid())
  guestId   String
  guest     Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  content   String
  author    String?
  createdAt DateTime @default(now())

  @@index([guestId])
}

model GuestMessage {
  id             String    @id @default(cuid())
  guestId        String
  guest          Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)
  reservationId  String?
  channel        String
  messageType    String
  direction      String    @default("outbound")
  subject        String?
  body           String
  deliveryStatus String    @default("sent")
  openedAt       DateTime?
  clickedAt      DateTime?
  repliedAt      DateTime?
  campaignId     String?
  createdAt      DateTime  @default(now())

  @@index([guestId])
}

model Campaign {
  id              String    @id @default(cuid())
  name            String
  type            String    @default("email")
  status          String    @default("draft")
  segment         String    @default("all")
  listingFilter   String?
  subject         String?
  body            String
  ctaText         String?
  ctaLink         String?
  scheduledAt     DateTime?
  sentAt          DateTime?
  totalRecipients Int       @default(0)
  totalSent       Int       @default(0)
  totalOpened     Int       @default(0)
  totalClicked    Int       @default(0)
  totalBounced    Int       @default(0)
  createdBy       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  recipients CampaignRecipient[]
}

model CampaignRecipient {
  id             String    @id @default(cuid())
  campaignId     String
  campaign       Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  guestId        String
  guest          Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)
  deliveryStatus String    @default("pending")
  sentAt         DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?

  @@unique([campaignId, guestId])
  @@index([campaignId])
  @@index([guestId])
}

model MessageTemplate {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("email")
  category  String   @default("general")
  subject   String?
  body      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CrmAutomation {
  id         String   @id @default(cuid())
  name       String
  trigger    String
  templateId String?
  delay      String?
  isActive   Boolean  @default(true)
  conditions String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model CrmActivityLog {
  id        String   @id @default(cuid())
  guestId   String?
  guest     Guest?   @relation(fields: [guestId], references: [id], onDelete: SetNull)
  action    String
  details   String?
  actor     String?
  createdAt DateTime @default(now())

  @@index([guestId])
}
